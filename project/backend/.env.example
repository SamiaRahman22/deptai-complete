# Application
APP_NAME="DeptAI - Department Assistant"
APP_VERSION="1.0.0"
DEBUG=true
FRONTEND_URL=http://localhost:3000

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///./deptai.db
REDIS_URL=redis://redis:6379/0  #NEW

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss_index
DOCUMENTS_PATH=./data/documents
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# Domain Restriction
DEPARTMENT_NAME="Computer Science & Engineering"
DOMAIN_KEYWORDS=course,curriculum,exam,assignment,thesis,attendance,faculty,professor,dean,department,grade,cgpa,credit,semester,enrollment,scholarship,transcript,fee,lab,research,procedure,deadline,notice,admission,internship,lecture,tutorial,supervisor,class,schedule
DOMAIN_THRESHOLD=0.35
